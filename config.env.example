# Copy this file to config.env. It is sourced by Bash, so quote values as shell values.
HARNESSVM_CPUS=4
HARNESSVM_MEMORY_GIB=8
HARNESSVM_DISK_GIB=30
HARNESSVM_VM_TYPE=vz
HARNESSVM_ARCH=aarch64
HARNESSVM_MOUNT_TYPE=virtiofs
HARNESSVM_TIMEZONE=Europe/Berlin
HARNESSVM_OPEN_BROWSER=1
HARNESSVM_START_TIMEOUT=10m
HARNESSVM_DESKTOP_WIDTH=1920
HARNESSVM_DESKTOP_HEIGHT=1080
# Selkies accepts 96, 120, 144, 168, 192, 216, 240, 264, or 288.
HARNESSVM_XFCE_DPI=96

# Harnesses loaded in new sessions. Available: codex, claude, opencode, pi, hermes, qwen.
HARNESSVM_HARNESSES=codex,claude
# Additional top-level home directories shared by every session.
HARNESSVM_PERSIST_DIRS=

# Comma-separated HOST:PORT entries allowed through the private-network firewall.
# Use host.lima.internal for services running on the host machine.
HARNESSVM_DEFAULT_ALLOW=
